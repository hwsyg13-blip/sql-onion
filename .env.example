# Supabase (필수) — Supabase 대시보드 → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# PortOne (결제) — https://portone.io 대시보드에서 테스트 키 발급
VITE_PORTONE_STORE_ID=store-xxxxxxx
VITE_PORTONE_CHANNEL_KEY_KAKAO=channel-key-xxxxxxx

# Google AdSense (승인 후 입력) — "ca-pub-" 로 시작하는 퍼블리셔 ID
VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx

# Google Analytics 4 — analytics.google.com → 관리 → 데이터 스트림 → 측정 ID (G-로 시작)
# 미설정 시 GA 코드는 자동 비활성화 (no-op)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# 오류 제보 수집 Apps Script 웹앱 URL (Google Sheet 에 누적 저장)
# 미설정 시 제보 내용이 클립보드에 복사되는 fallback 으로 동작
VITE_BUG_REPORT_URL=https://script.google.com/macros/s/AKfycb.../exec

# 서버 전용 — Vercel env에만. 브라우저 번들에 절대 넣지 않음 (VITE_ 접두사 없음)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
PORTONE_API_SECRET=portone-api-secret-xxxxxxx
