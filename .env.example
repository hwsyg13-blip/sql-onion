# Supabase (필수) — Supabase 대시보드 → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# PortOne (결제) — https://portone.io 대시보드에서 테스트 키 발급
